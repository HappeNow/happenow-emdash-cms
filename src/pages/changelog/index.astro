---
import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";

const { entries, cacheHint } = await getEmDashCollection("changelog", {
	orderBy: { published_at: "desc" },
});

Astro.cache.set(cacheHint);

const formatDate = (date: Date) =>
	date.toLocaleDateString("en-US", {
		year: "numeric",
		month: "long",
		day: "numeric",
	});
---

<Base
	title="Changelog"
	description="Product updates and release notes for HappeNow."
>
	<div class="changelog-page">
		<header class="page-header">
			<h1 class="page-title">Changelog</h1>
			<p class="page-description">
				What's new and what's changed.
			</p>
		</header>

		{
			entries.length === 0 ? (
				<p class="empty">No releases yet.</p>
			) : (
				<ol class="release-list">
					{entries.map((entry) => (
						<li class="release">
							<a href={`/changelog/${entry.id}`} class="release-link">
								<div class="release-meta">
									{entry.data.version && (
										<span class="release-version">v{entry.data.version}</span>
									)}
									{entry.data.publishedAt && (
										<time>{formatDate(entry.data.publishedAt)}</time>
									)}
								</div>
								<h2 class="release-title">{entry.data.title}</h2>
								{entry.data.summary && (
									<p class="release-summary">{entry.data.summary}</p>
								)}
							</a>
						</li>
					))}
				</ol>
			)
		}
	</div>
</Base>

<style>
	.changelog-page {
		max-width: var(--content-width);
		margin: 0 auto;
		padding: var(--spacing-8) var(--spacing-6) var(--spacing-16);
	}

	.page-header {
		margin-bottom: var(--spacing-12);
	}

	.page-title {
		font-size: var(--font-size-4xl);
		font-weight: 700;
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--spacing-2);
	}

	.page-description {
		font-size: var(--font-size-lg);
		color: var(--color-muted);
	}

	.empty {
		color: var(--color-muted);
		font-size: var(--font-size-lg);
	}

	.release-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
	}

	.release {
		padding: var(--spacing-8) 0;
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.release:first-child {
		padding-top: 0;
	}

	.release:last-child {
		border-bottom: none;
	}

	.release-link {
		display: block;
		text-decoration: none;
		color: inherit;
	}

	.release-meta {
		display: flex;
		align-items: center;
		gap: var(--spacing-3);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		margin-bottom: var(--spacing-2);
	}

	.release-version {
		font-family: var(--font-mono);
		font-size: var(--font-size-sm);
		color: var(--color-text);
		background: var(--color-surface);
		padding: var(--tag-padding-y) var(--spacing-2);
		border-radius: var(--radius);
	}

	.release-title {
		font-size: var(--font-size-2xl);
		font-weight: 600;
		line-height: var(--leading-snug);
		letter-spacing: var(--tracking-snug);
		margin-bottom: var(--spacing-2);
		transition: color var(--transition-fast);
	}

	.release-link:hover .release-title {
		color: var(--color-accent);
	}

	.release-summary {
		font-size: var(--font-size-lg);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
	}

	@media (max-width: 600px) {
		.changelog-page {
			padding: var(--spacing-6) var(--spacing-4) var(--spacing-12);
		}

		.page-title {
			font-size: var(--font-size-3xl);
		}

		.release-title {
			font-size: var(--font-size-xl);
		}
	}
</style>
